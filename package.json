{
  "name": "mecanografia",
  "version": "0.1.0",
  "description": "Entrenador modular de mecanografía con ejercicios expertos, métricas de progreso y soporte PWA.",
  "private": true,
  "packageManager": "npm@10.9.8",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "node --test",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "tauri:dev": "cargo tauri dev",
    "tauri:build": "cargo tauri build"
  },
  "keywords": [
    "mecanografia",
    "typing",
    "practice",
    "pwa"
  ],
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@tauri-apps/cli": "latest",
    "concurrently": "latest",
    "electron": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vite-plugin-pwa": "latest",
    "wait-on": "latest"
  }
}
